{
  "name": "jmdict-hakase",
  "version": "0.1.0",
  "description": "A query-shaped PostgreSQL build of the JMdict Japanese-English dictionary, with CJK full-text and pgvector semantic search and a thin Fastify API.",
  "type": "module",
  "license": "MIT",
  "author": "Lee Doughty",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "migration:new": "supabase migration new",
    "migration:up": "supabase migration up",
    "data:download": "node src/download.ts",
    "data:load": "node src/load.ts",
    "dev": "node --watch src/server/index.ts",
    "serve": "node src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "supabase": "2.106.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@fastify/rate-limit": "11.0.0",
    "fastify": "5.8.5",
    "postgres": "3.4.9",
    "stream-chain": "4.2.5",
    "stream-json": "3.4.0",
    "tar": "7.5.16"
  }
}
